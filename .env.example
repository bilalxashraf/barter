NODE_ENV=development

# Shared
# Use the Supabase pooled Postgres connection string here.
DATABASE_URL=postgresql://postgres.[project-ref]:password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
# Optional explicit alias if you prefer a Supabase-named variable.
SUPABASE_DATABASE_URL=
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
CHAIN_RPC_URL_BASE=https://mainnet.base.org
CHAIN_RPC_URL_ARBITRUM=https://arb1.arbitrum.io/rpc
CHAIN_RPC_URL_OPTIMISM=https://mainnet.optimism.io
CHAIN_RPC_URL_ETHEREUM=https://ethereum-rpc.publicnode.com
BARTER_ENCRYPTION_KEY=replace-with-32-byte-base64-value
BARTER_SESSION_COOKIE_NAME=barter_session
BARTER_BASE_URL=http://localhost:3000

# API
API_PORT=4001
API_HOST=0.0.0.0
API_LOG_LEVEL=info
API_CORS_ORIGIN=http://localhost:3000
API_CUSTODY_MODE=custodial
JOB_QUEUE_SCHEMA=public
X_WEBHOOK_MODE=webhook
X_WEBHOOK_SECRET=replace-with-webhook-secret
X_POLLING_ENABLED=true
X_POLLING_INTERVAL_SECONDS=300
X_APP_BEARER_TOKEN=replace-with-app-only-bearer
X_BARTER_HANDLE=barterpayments
X_REPLY_DRY_RUN=true

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:4001
NEXT_PUBLIC_BARTER_HANDLE=barterpayments
WEB_PORT=3000
WEB_CUSTODY_MODE=custodial
# The Barter X account should sign in once through the web app so its OAuth
# credential is stored and the worker can poll mentions + post replies.
X_CLIENT_ID=replace-with-x-client-id
X_CLIENT_SECRET=replace-with-x-client-secret
X_REDIRECT_URI=http://localhost:3000/api/auth/x/callback

# Worker
WORKER_LOG_LEVEL=info
WORKER_REPLY_DRY_RUN=true
WORKER_CUSTODY_MODE=custodial
# Polling uses the shared X_CLIENT_ID / X_CLIENT_SECRET values above.
