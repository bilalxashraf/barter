{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "resolveJsonModule": true,
    "allowJs": false,
    "checkJs": false,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@barter/config": ["packages/config/src/index.ts"],
      "@barter/contracts": ["packages/contracts/src/index.ts"],
      "@barter/domain": ["packages/domain/src/index.ts"],
      "@barter/db": ["packages/db/src/index.ts"],
      "@barter/social": ["packages/social/src/index.ts"],
      "@barter/chains": ["packages/chains/src/index.ts"],
      "@barter/custody": ["packages/custody/src/index.ts"],
      "@barter/observability": ["packages/observability/src/index.ts"],
      "@barter/testing": ["packages/testing/src/index.ts"]
    }
  }
}

